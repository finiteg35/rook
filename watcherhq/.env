# OpenClaw AI Engine
OPENCLAW_API_URL=http://localhost:3000
OPENCLAW_API_KEY=

# Database (SQLite — path is relative to where uvicorn is invoked)
# Docker: uses /app/data/ (mounted volume) → keep as shown below
# Bare-metal: change to sqlite:///./watcherhq.db or a full path
DATABASE_URL=sqlite:///./data/watcherhq.db

# JWT Authentication
# Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Stripe Payments
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE
STRIPE_PRO_PRICE_ID=YOUR_STRIPE_PRO_PRICE_ID_HERE
STRIPE_BUSINESS_PRICE_ID=YOUR_STRIPE_BUSINESS_PRICE_ID_HERE

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=WatcherHQ <noreply@yourdomain.com>

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# App URL (used in notification links)
APP_URL=https://yourdomain.com

# Frontend env vars (Next.js)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY_HERE
